         RowBox[{
          RowBox[{"rho0", "[", "t", "]"}], ",", "t"}], "]"}]}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"eq1Simp", "=", 
     RowBox[{"Simplify", "[", 
