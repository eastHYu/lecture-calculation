Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Hr", "[", "a_", "]"}], ":=", 
   RowBox[{"Piecewise", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"10", ",", 
        RowBox[{"a", "<=", "100"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"10", "*", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"a", "/", "100"}], ")"}], "^", "2"}]}], ",", 
        RowBox[{"a", ">", "100"}]}], "}"}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[Lambda]", "[", "a_", "]"}], ":=", "a"}], ";"}], "  "}], "\n", 
 RowBox[{"LogLogPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Hr", "[", "a", "]"}], ",", 
     RowBox[{"\[Lambda]", "[", "a", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"a", ",", "1", ",", "10000"}], "}"}], ",", 
   RowBox[{"PlotStyle", "->", 
    RowBox[{"{", 
     RowBox[{"Thick", ",", "Dashed"}], "}"}]}], ",", 
   RowBox[{"PlotLegends", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*SuperscriptBox[\(H\), \
\(-1\)]\)\[Proportional]\!\(\*SuperscriptBox[\(a\), \(2\)]\)(RD)\>\"", ",", 
      "\"\<\[Lambda]\[Proportional]a\>\""}], "}"}]}]}], "]"}]}], "Input",
