67d228ebc72f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"f", "[", "t_", "]"}], ":=", 
  RowBox[{"Re", "[", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"1000", " ", "\[ImaginaryI]", " ", 
       SqrtBox[
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "2"}], " ", "t"}]]]}]], " ", 
     RowBox[{"(", 
      RowBox[{"\[ImaginaryI]", "+", 
       RowBox[{"1000", " ", 
        SqrtBox[
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "t"}]]]}]}], ")"}]}], " ", "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "1000"}], " ", "\[ImaginaryI]", " ", 
        SqrtBox[
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "t"}]]]}]], " ", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"1000", " ", "\[ImaginaryI]", " ", 
         SqrtBox[
