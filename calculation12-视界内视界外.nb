Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"X", "''"}], "[", "t", "]"}], "+", 
     RowBox[{"3", 
      RowBox[{
       RowBox[{"X", "'"}], "[", "t", "]"}]}], "+", 
     RowBox[{
      FractionBox[
       SuperscriptBox["k", "2"], 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"]], 
      RowBox[{"X", "[", "t", "]"}]}]}], "==", "0"}], ",", 
   RowBox[{"X", "[", "t", "]"}], ",", "t"}], "]"}]], "Input",
 CellChangeTimes->{{3.982536345972801*^9, 3.982536359063303*^9}},
