          SuperscriptBox["\[ExponentialE]", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "t"}]]]}]], " ", 
       RowBox[{"(", 
        RowBox[{"1", "+", 
         RowBox[{"1000", " ", "\[ImaginaryI]", " ", 
          SqrtBox[
