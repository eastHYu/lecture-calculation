          RowBox[{"Integrate", "[", 
           RowBox[{
            RowBox[{"eq0xScalar", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", "x"}], "]"}]}], ",", 
         RowBox[{"BTilde", "[", 
          RowBox[{"t", ",", "x", ",", "y", ",", "z"}], "]"}]}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "//", "Simplify"}]}], ";"}], "\n", 
